# Caddy serves as the public TLS terminator and reverse proxy in front
# of the giper-pm stack. Auto-TLS via Let's Encrypt is on by default
# for any host with a real DNS name.
#
# Two responsibilities:
#   1. Terminate HTTPS on the public host (PUBLIC_HOST env)
#   2. Proxy everything to web; route /ws/* to the ws container with
#      WebSocket upgrade headers preserved.
#
# WebSocket on a sub-path keeps everything under one cert / DNS entry.
# Browsers connect to wss://<host>/ws so NEXT_PUBLIC_WS_URL is
# wss://<host>/ws.

{$PUBLIC_HOST} {
	encode zstd gzip

	# Health probe — answers without forwarding so monitoring doesn't
	# rely on the upstream being up.
	handle /healthz {
		respond "ok" 200
	}

	# WebSocket subpath → ws container. Caddy auto-detects the upgrade
	# header but we make it explicit for clarity.
	@ws {
		path /ws*
	}
	handle @ws {
		uri strip_prefix /ws
		reverse_proxy ws:3001 {
			header_up Host {host}
		}
	}

	# Everything else → Next.js.
	handle {
		reverse_proxy web:3000 {
			header_up X-Forwarded-Proto {scheme}
			header_up X-Forwarded-For {remote_host}
			header_up X-Real-IP {remote_host}
			header_up Host {host}
		}
	}

	# Modest rate limit defaults via Caddy's standard config — heavy
	# limits live at the application layer where they have context.
	log {
		output stdout
		format console
	}

	tls {$ACME_EMAIL}
}

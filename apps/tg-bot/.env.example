# Telegram bot token from @BotFather (https://t.me/BotFather → /newbot).
TG_BOT_TOKEN=

# Same DATABASE_URL as the web app — read-only would be enough but
# we share the schema for now.
DATABASE_URL=postgresql://giper:giper@localhost:5432/giper_pm

# Same Redis as the web app — used for short-lived pairing codes.
REDIS_URL=redis://localhost:6379

# Public base URL of the web app, included in messages with deep links.
PUBLIC_BASE_URL=http://localhost:3000

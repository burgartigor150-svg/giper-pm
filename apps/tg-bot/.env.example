# Multi-bot runner. There is no single org-wide token any more — each PM
# connects their personal BotFather bot via the giper-pm web UI
# ("Интеграции → Telegram"). Tokens are stored AES-256-GCM-encrypted in
# Postgres; the runner decrypts at boot and on every reload event.

# 32-byte master key (hex or base64) used to decrypt UserTelegramBot
# tokens. MUST match the value in apps/web/.env (TG_TOKEN_ENC_KEY).
# Generate one:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TG_TOKEN_ENC_KEY=

# Same Postgres as the web app — reads UserTelegramBot rows and writes
# Task / TelegramProjectMessage / ProjectTelegramChat changes.
DATABASE_URL=postgresql://giper:giper@localhost:5432/giper_pm

# Redis: short-lived /linkproj codes + pub/sub channel `tg:bots:reload`.
REDIS_URL=redis://localhost:6379

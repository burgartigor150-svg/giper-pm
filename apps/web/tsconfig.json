{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "ES2022"],
    "jsx": "preserve",
    "allowJs": true,
    "noEmit": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"],
      "@giper/db": ["../../packages/db/src/index.ts"],
      "@giper/shared": ["../../packages/shared/src/index.ts"],
      "@giper/shared/*": ["../../packages/shared/src/*"],
      "@giper/ui": ["../../packages/ui/src/index.ts"],
      "@giper/ui/*": ["../../packages/ui/src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules", ".next", ".turbo"]
}

DATABASE_URL=postgresql://giper:giper@localhost:5432/giper_pm
REDIS_URL=redis://localhost:6379

# Auth.js
AUTH_SECRET=
AUTH_URL=http://localhost:3000
# Опционально: если AUTH_URL не задан при сборке, для подсказок в UI
NEXT_PUBLIC_APP_URL=http://localhost:3000
AUTH_TRUST_HOST=true
# Публичный origin этого деплоя — issuer и базовый URL OAuth/MCP-эндпоинтов
# (lib/oauth/core.ts → baseUrl()). ДОЛЖЕН совпадать с AUTH_URL: на него
# уходит callbackUrl при login-bounce в /api/oauth/authorize, и NextAuth
# отбросит callbackUrl с чужого origin → поток авторизации молча сломается.
# Если не задан, падает в прод-дефолт https://pm.since-b24-ru.ru.
PUBLIC_BASE_URL=http://localhost:3000
# SSO через Google (опционально). Кнопка «Войти через Google» и сам провайдер
# включаются ТОЛЬКО когда заданы обе переменные — иначе поведение как раньше.
# Создать OAuth-клиент: console.cloud.google.com → Credentials → OAuth client ID
# (Web), redirect URI: <AUTH_URL>/api/auth/callback/google.
# Войти смогут только пользователи, уже заведённые в системе (по e-mail).
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# SSO через Bitrix24 («Войти через Битрикс24», как на hr.promo-giper-ai.ru).
# Кнопка и провайдер включаются ТОЛЬКО когда заданы обе переменные; тогда
# email/пароль-форма на /login скрывается и остаётся один вход через Bitrix24
# (Credentials-провайдер остаётся в бэкенде как аварийный вход).
# «Локальное приложение» на портале Bitrix24 (OAuth 2.0). redirect_uri:
# <PUBLIC_BASE_URL>/api/auth/b24/callback
# (для прод: https://pm.since-b24-ru.ru/api/auth/b24/callback).
# Портал по умолчанию giper.bitrix24.ru; переопределить через BITRIX24_PORTAL.
# Пускает ТОЛЬКО существующих активных пользователей giper-pm (по e-mail).
BITRIX24_OAUTH_CLIENT_ID=
BITRIX24_OAUTH_CLIENT_SECRET=
BITRIX24_PORTAL=giper.bitrix24.ru

# 32-byte master key (hex or base64) used to encrypt personal Telegram bot
# tokens stored in UserTelegramBot. Must match apps/tg-bot/.env
# (TG_TOKEN_ENC_KEY). Generate one:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TG_TOKEN_ENC_KEY=

# Web Push (browser notifications). Generate ONCE per environment and
# keep them stable — rotating these invalidates every existing
# subscription. Generation:
#   node -e "const w=require('web-push');const k=w.generateVAPIDKeys();console.log('VAPID_PUBLIC_KEY='+k.publicKey);console.log('VAPID_PRIVATE_KEY='+k.privateKey)"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Required by the Web Push spec. Push services (Apple, FCM) contact
# this address on abuse / delivery issues. Use a real mailbox on
# your domain.
VAPID_SUBJECT=mailto:postmaster@since-b24-ru.ru

// ============================================================================
// SCHEMA.prisma — модель данных giper-pm
// Источник истины. Любые изменения модели делаются ЗДЕСЬ И СНАЧАЛА.
// ============================================================================

generator client {
  provider      = "prisma-client-js"
  // native = host (macOS/Linux dev). linux-musl-openssl-3.0.x = Alpine prod image.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// AUTH & USERS
// ============================================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String
  avatarUrl     String?
  image         String?   // mirrors avatarUrl, populated by Auth.js providers
  role          UserRole  @default(MEMBER)
  hourlyRate    Decimal?  @db.Decimal(10, 2)
  timezone      String    @default("Europe/Moscow")
  locale        String    @default("ru")
  isActive      Boolean   @default(true)

  // Credentials auth
  passwordHash           String?
  mustChangePassword     Boolean   @default(false)
  lastPasswordChangeAt   DateTime?

  /// Opt-in per-owner CRM access for non-ADMIN/PM users. Default false →
  /// inert until an admin grants it. ADMIN/PM see the whole CRM regardless;
  /// a MEMBER with this flag becomes a "scoped sales rep" who sees/edits only
  /// the Deal/Contact/Lead they own. VIEWER never qualifies even if set.
  crmAccess              Boolean   @default(false)

  // External integrations
  bitrixUserId  String?   @unique // user.ID in cloud Bitrix24
  kaitenUserId  String?   @unique // user id in Kaiten (for attribution/assignee)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  // Auth.js relations
  accounts          Account[]
  sessions          Session[]

  // Domain relations
  consents          UserConsent[]
  /// Per-browser Web Push subscriptions. One row per device/browser
  /// the user opted-in from.
  pushSubscriptions PushSubscription[]
  agentDevices      AgentDevice[]
  ownedProjects     Project[]            @relation("ProjectOwner")
  /// CRM ownership (org-level sales).
  ownedContacts     Contact[]            @relation("ContactOwner")
  ownedDeals        Deal[]               @relation("DealOwner")
  /// CRM leads owned (top-of-funnel, pre-qualification).
  ownedLeads        Lead[]               @relation("LeadOwner")
  /// Custom-role: the user's org-level assignment (≤1), plus authored/assigned
  /// trails. Additive — a null assignment ⇒ the UserRole baseline (inert).
  customRole          UserCustomRole?           @relation("UserCustomRoleAssignee")
  createdCustomRoles  CustomRole[]              @relation("CustomRoleCreator")
  assignedCustomRoles UserCustomRole[]          @relation("UserCustomRoleAssigner")
  projectCustomRoles  ProjectMemberCustomRole[] @relation("ProjectMemberCustomRoleUser")
  /// Service-desk tickets assigned to this agent.
  assignedTickets   Ticket[]             @relation("TicketAssignee")
  memberProjects    ProjectMember[]
  /// Bitrix-mirror project memberships. Used by visibility checks
  /// alongside task stakes (see ProjectBitrixMember).
  bitrixMemberProjects ProjectBitrixMember[]
  assignedTasks     Task[]               @relation("TaskAssignee")
  createdTasks      Task[]               @relation("TaskCreator")
  reviewerTasks     Task[]               @relation("TaskReviewer")
  timeEntries       TimeEntry[]
  activities        Activity[]
  comments          Comment[]
  auditLogs         AuditLog[]
  integrationLinks  UserIntegrationLink[]
  notifications     Notification[]
  /// Per-kind in-app notification preferences (mute categories).
  notificationPreferences NotificationPreference[]
  taskWatching      TaskWatcher[]
  positions         UserPosition[]
  taskAssignments   TaskAssignment[]
  // PM team membership: edges where this user is a member of someone's team.
  inPmTeams         PmTeamMember[]       @relation("PmTeamMembers")
  // PM team ownership: edges where this user is the PM of a team.
  pmTeam            PmTeamMember[]       @relation("PmTeamOwner")
  /// Org-level user-group memberships.
  groupMemberships  UserGroupMember[]
  /// Personal API tokens for the public REST API (act-as this user).
  apiTokens         ApiToken[]
  /// Saved board/list filter presets owned by this user.
  savedFilters      SavedFilter[]        @relation("SavedFilterOwner")
  /// Components this user leads.
  componentLeads    Component[]          @relation("ComponentLead")

  // Tags assigned by this user (audit trail of tag activity).
  tagAssignments    TaskTag[]            @relation("TaskTagAssigner")

  // Messenger relations.
  channelsCreated     Channel[]          @relation("ChannelCreator")
  channelMemberships  ChannelMember[]    @relation("ChannelMembership")
  channelInvitesCreated ChannelInvite[]  @relation("ChannelInviteCreator")
  calendarEventsCreated CalendarEvent[]  @relation("CalendarEventCreator")
  calendarEventAttendances CalendarEventAttendee[] @relation("CalendarEventAttendee")
  messages            Message[]          @relation("MessageAuthor")
  messageReactions    MessageReaction[]  @relation("MessageReactor")
  messageMentions     MessageMention[]   @relation("MessageMentioned")

  /// Telegram groups/channels this user linked to a giper-pm project.
  linkedProjectTelegramChats ProjectTelegramChat[] @relation("ProjectTelegramLinker")

  /// Personal Telegram bots (BotFather) the user connected for project harvest.
  telegramBots      UserTelegramBot[]

  /// Meetings the user created (kicked off the room).
  createdMeetings   Meeting[]            @relation("MeetingCreator")
  /// Per-meeting participation rows (joined LiveKit rooms).
  meetingPresence   MeetingParticipant[]
  /// Guest-invite links the user has minted.
  meetingInvitesCreated MeetingInvite[]  @relation("MeetingInviteCreator")

  @@index([role, isActive])
}

// ----- Auth.js (NextAuth v5) adapter models -------------------------------

model Account {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum UserRole {
  ADMIN       // полный доступ, биллинг, настройки
  PM          // создаёт проекты, видит отчёты команды
  MEMBER      // обычный сотрудник, видит свои данные + общие задачи
  VIEWER      // read-only, например для клиента
}

// Specialty (должность) — what this person actually does. Decoupled
// from UserRole (org-level permission) — a person can be a FRONTEND
// who happens to also have PM role. One user can hold multiple
// positions via UserPosition.
enum Position {
  FRONTEND
  BACKEND
  FULLSTACK
  MOBILE
  QA
  QA_AUTO
  DESIGNER
  UX
  ANALYST
  BA            // business analyst
  PM
  LEAD
  DEVOPS
  SRE
  CONTENT
  MARKETING
  OTHER
}

model UserPosition {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  position  Position
  // primary = the headline specialty shown next to the user's name.
  primary   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([userId, position])
  @@index([position])
}

// PM "team": a private roster a PM curates so they can quickly pick
// from "my people" when assigning a task. People can sit in multiple
// PMs' teams simultaneously — that's the whole "shared resource"
// point. Capacity is computed on the fly from active assignments.
model PmTeamMember {
  id        String   @id @default(cuid())
  pmId      String
  pm        User     @relation("PmTeamOwner", fields: [pmId], references: [id], onDelete: Cascade)
  memberId  String
  member    User     @relation("PmTeamMembers", fields: [memberId], references: [id], onDelete: Cascade)
  // Free-form note from the PM about why this person is on the team.
  note      String?
  createdAt DateTime @default(now())

  @@unique([pmId, memberId])
  @@index([memberId])
}

/// Org-level user group: a named set of users an admin curates
/// to bulk-add to projects (and, later, to grant group-level access).
model UserGroup {
  id          String            @id @default(cuid())
  name        String            @unique
  description String            @default("")
  createdById String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  members     UserGroupMember[]
}

/// Membership edge: a user belongs to a UserGroup.
model UserGroupMember {
  id        String    @id @default(cuid())
  groupId   String
  group     UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  addedAt   DateTime  @default(now())

  @@unique([groupId, userId])
  @@index([userId])
}

/// Personal API token for the public REST API. The raw token (gpm_<hex>) is
/// shown once at creation; only its SHA-256 hash is stored. Requests using it
/// act as the owning user — visibility/permissions are the user's own.
model ApiToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  /// SHA-256 hex of the raw token.
  tokenHash  String    @unique
  /// Leading chars of the token for display (e.g. "gpm_ab12cd…").
  prefix     String
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
}

// ---- OAuth 2.1 for the MCP server (remote connectors, e.g. claude.ai) ----
// Self-contained authorization server: Dynamic Client Registration (RFC 7591),
// Authorization Code + PKCE, and bearer access/refresh tokens. userId/clientId
// are plain scalars (explicit lookups, no cascade) to stay isolated from the
// User model's relation graph.

/// A client registered via Dynamic Client Registration (one per MCP connector).
model OAuthClient {
  id           String   @id // client_id (random)
  secretHash   String? // sha-256 of client_secret; null for public (PKCE) clients
  name         String?
  redirectUris String[]
  createdAt    DateTime @default(now())
}

/// Short-lived authorization code (single use), bound to the PKCE challenge.
model OAuthAuthCode {
  id            String    @id @default(cuid())
  codeHash      String    @unique
  clientId      String
  userId        String
  redirectUri   String
  codeChallenge String // PKCE S256 challenge
  scope         String?
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime  @default(now())

  @@index([expiresAt])
}

/// Bearer access token issued to a connector (hashed). Accepted by /api/mcp.
model OAuthAccessToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  clientId  String
  userId    String
  scope     String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

/// Refresh token (hashed) — exchanged at /token for a fresh access token.
model OAuthRefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  clientId  String
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

// Multi-assignment with role: a single task can have a frontend, a
// backend, and a QA all assigned. Distinct from Task.assigneeId which
// remains the "primary" / Bitrix-mirror slot. The single-assignee
// field on Task is preserved for back-compat with all the existing
// canEdit/notification/sync code.
model TaskAssignment {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  position  Position
  createdAt DateTime @default(now())
  createdById String

  @@unique([taskId, userId, position])
  @@index([userId])
  @@index([taskId])
}

model UserConsent {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        ConsentType
  granted     Boolean
  grantedAt   DateTime?
  revokedAt   DateTime?
  ipAddress   String?       // для аудита
  userAgent   String?

  @@unique([userId, type])
  @@index([userId])
}

/// Web Push subscription. One row per browser+device the user opted in
/// from (so one user can have a desktop Chrome subscription AND a
/// mobile Safari one). `endpoint` is globally unique — that's the
/// upsert key when the same browser re-subscribes (e.g. service-worker
/// re-registration after a domain change).
///
/// Cleanup: when web-push.sendNotification returns 410 Gone (Apple,
/// Mozilla, Google all use this for unsubscribed endpoints) we delete
/// the row so we don't keep sending into the void.
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Push service URL the browser handed us. Globally unique.
  endpoint  String   @unique
  /// Public key half of the ECDH pair used to encrypt the payload.
  p256dh    String
  /// HMAC auth secret derived during subscribe.
  authSec   String
  /// User-Agent at subscribe time. Just for diagnostics in the
  /// settings panel ("Chrome 125 / macOS"); not used for routing.
  userAgent String?
  createdAt DateTime @default(now())
  lastUsedAt DateTime?

  @@index([userId])
}

enum ConsentType {
  WINDOW_TRACKING       // active-win, browser tabs
  IDLE_DETECTION        // node-system-idle-time
  SCREENSHOTS           // периодические скриншоты
  GIT_ACTIVITY          // привязка коммитов к задачам автоматически
  CALENDAR_SYNC         // подтягивать встречи как TimeEntry
}

// Устройство, на котором стоит десктоп-агент или браузерное расширение.
model AgentDevice {
  id            String       @id @default(cuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind          DeviceKind
  name          String       // "MacBook Pro Игоря" / "Chrome on Windows"
  os            String?
  osVersion     String?
  appVersion    String?
  authToken     String       @unique  // hashed token для аутентификации агента
  pairedAt      DateTime     @default(now())
  lastSeenAt    DateTime?
  isActive      Boolean      @default(true)
  
  activities    Activity[]
  screenshots   Screenshot[]
  
  @@index([userId, isActive])
}

enum DeviceKind {
  DESKTOP_AGENT
  BROWSER_EXTENSION
}

// ============================================================================
// PROJECTS & TASKS
// ============================================================================

model Project {
  id            String          @id @default(cuid())
  key           String          @unique  // "GFM", "OPS" — короткий префикс для тасков
  name          String
  description   String?
  client        String?         // имя клиента (для D2C-проектов)
  status        ProjectStatus   @default(ACTIVE)
  budgetHours   Decimal?        @db.Decimal(10, 2)
  hourlyRate    Decimal?        @db.Decimal(10, 2)  // переопределяет user.hourlyRate
  startDate     DateTime?
  deadline      DateTime?
  ownerId       String
  owner         User            @relation("ProjectOwner", fields: [ownerId], references: [id])

  // External integrations (read-only mirror).
  externalId       String?         // sonet group / repo / external project key
  externalSource   String?         // "bitrix24" | "github" | ...

  // WIP-лимиты по колонкам канбана: { TODO: 5, IN_PROGRESS: 3, REVIEW: 2 }.
  // null/missing key = без лимита. Soft-limit only — система не блокирует
  // переход, а подсвечивает колонку красным при превышении.
  wipLimits     Json?

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  archivedAt    DateTime?

  members       ProjectMember[]
  /// Mirrored membership from Bitrix sonet_group. Drives visibility
  /// (see ProjectBitrixMember docstring) — a user appears here as
  /// soon as Bitrix sync sees them in the workgroup.
  bitrixMembers ProjectBitrixMember[]
  tasks         Task[]
  integrations  ProjectIntegration[]
  /// Connected GitHub/GitLab repositories (in-app setup: token + auto webhook).
  repoConnections RepoConnection[]
  kaitenSuggestions KaitenMatchSuggestion[]
  tags          Tag[]
  channels      Channel[]
  /// Telegram supergroups / channels mirrored into giper-pm for harvest → tasks.
  telegramChats ProjectTelegramChat[]
  /// Video meetings tied to this project (LiveKit + transcription).
  meetings      Meeting[]
  /// Lightweight calendar entries scoped to this project.
  calendarEvents CalendarEvent[]
  /// Configurable board: columns + swimlanes (Phase 0).
  boardColumns   BoardColumn[]
  boardSwimlanes BoardSwimlane[]
  /// Custom fields defined for this project (Phase 3).
  customFields   CustomFieldDefinition[]
  /// Automation rules for this project (Phase 4).
  automationRules AutomationRule[]
  /// Documents (wiki) in this project.
  documents       Document[]
  /// Reusable card templates for this project.
  cardTemplates   CardTemplate[]
  /// Recurring cards (auto-created on a schedule).
  recurringTasks  RecurringTask[]
  /// Outgoing webhooks fired on card/board events in this project.
  webhooks        Webhook[]
  /// Scrum sprints (time-boxed iterations) for this project.
  sprints         Sprint[]
  /// Releases / versions (Jira fixVersion) for grouping cards by what ships.
  versions        Version[]
  /// Components (Jira component) — product areas for grouping cards.
  components      Component[]
  /// Configurable-workflow transition allowlist (Jira workflow). Empty = no
  /// restriction (any status move allowed) — inert until the project adds rows.
  workflowTransitions WorkflowTransition[]
  /// CRM deals linked to this project (org-level sales → delivery handoff).
  deals           Deal[]          @relation("DealProject")
  /// Per-project custom-role assignments. Reserved for v2 — no writer in v1.
  memberCustomRoles ProjectMemberCustomRole[]
  /// Saved board/list filter presets scoped to this project.
  savedFilters    SavedFilter[]
  /// Space (folder) this project belongs to. Nullable = ungrouped.
  spaceId         String?
  space           Space?          @relation(fields: [spaceId], references: [id], onDelete: SetNull)

  @@unique([externalSource, externalId])
  @@index([status])
  @@index([ownerId])
  @@index([spaceId])
}

/// Outgoing webhook: POSTs a JSON event to an external URL when
/// a subscribed card/board event fires in the project. Payloads are signed
/// with HMAC-SHA256 over `secret`. `events` holds subscribed event-type
/// strings (e.g. "task.created", "card.enters_column").
model Webhook {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  url         String
  /// Shared secret for the X-Giper-Signature HMAC header.
  secret      String
  /// Subscribed event types. Empty = subscribed to nothing (inert).
  events      String[]
  active      Boolean  @default(true)
  /// Lightweight delivery observability — last attempt outcome.
  lastStatus  Int?
  lastError   String?
  lastFiredAt DateTime?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId, active])
}

/// Card template: a reusable blueprint for creating tasks with
/// a predefined title / description / type / priority. Project-scoped.
model CardTemplate {
  id           String       @id @default(cuid())
  projectId    String
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  /// Name shown in the template picker (distinct from the card title).
  name         String
  /// Default values applied to the new card.
  title        String       @default("")
  description  String       @default("")
  type         TaskType     @default(TASK)
  priority     TaskPriority @default(MEDIUM)
  /// Display order in the picker / settings list.
  order        Int          @default(0)
  createdById  String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([projectId, order])
}

/// Recurring card: a blueprint that auto-creates a task every
/// `intervalDays` days. The /api/cron/recurring scanner materializes due rows
/// (nextRunAt <= now) and advances nextRunAt. Recurrence is a simple day
/// interval (covers daily/weekly/biweekly) — not full RRULE yet.
model RecurringTask {
  id           String       @id @default(cuid())
  projectId    String
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  /// Card fields applied to each created task.
  title        String
  description  String       @default("")
  type         TaskType     @default(TASK)
  priority     TaskPriority @default(MEDIUM)
  /// Optional default assignee for the created card.
  assigneeId   String?
  /// Recurrence cadence in days (>= 1).
  intervalDays Int
  /// When the next card is due to be created.
  nextRunAt    DateTime
  /// When the last card was actually created (null until first run).
  lastRunAt    DateTime?
  active       Boolean      @default(true)
  createdById  String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([active, nextRunAt])
  @@index([projectId])
}

enum SprintStatus {
  PLANNED   // defined, not started
  ACTIVE    // current sprint — burndown reads from this one
  CLOSED    // completed; incomplete cards carried out
}

/// Scrum sprint: a time-boxed iteration scoped to a project.
/// At most ONE ACTIVE per project — enforced in the action layer
/// (startSprintAction), NOT a DB partial index, because CI uses `prisma db push`.
model Sprint {
  id          String       @id @default(cuid())
  projectId   String
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  goal        String?      @db.Text
  startDate   DateTime?
  endDate     DateTime?
  status      SprintStatus @default(PLANNED)
  closedAt    DateTime?
  createdById String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  tasks       Task[]
  snapshots   SprintSnapshot[]

  @@index([projectId, status])
}

enum VersionStatus {
  PLANNED   // upcoming release, still collecting work
  RELEASED  // shipped
  ARCHIVED  // shelved / superseded
}

/// Release / version (Jira fixVersion): a named target a project's cards are
/// slated for. Additive + inert — until a version exists no card is versioned
/// and every query is byte-identical to today. Cards link via Task.versionId
/// (SetNull on delete), so deleting a version never deletes its cards.
model Version {
  id          String        @id @default(cuid())
  projectId   String
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  description String?       @db.Text
  status      VersionStatus @default(PLANNED)
  /// Planned or actual release date (nullable).
  releaseDate DateTime?
  /// Stamped when status moves to RELEASED.
  releasedAt  DateTime?
  createdById String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  tasks       Task[]

  @@index([projectId, status])
}

/// Component (Jira component): a named product area within a project (e.g.
/// "Frontend", "API", "Billing"). Additive + inert — until one exists no card is
/// categorized. Cards link via Task.componentId (SetNull on delete).
model Component {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  description String?  @db.Text
  /// Optional component lead (a user). SetNull if that user is removed.
  leadId      String?
  lead        User?    @relation("ComponentLead", fields: [leadId], references: [id], onDelete: SetNull)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tasks       Task[]

  @@index([projectId])
}

/// One allowed status move in a project's configurable workflow (Jira workflow).
/// A project with ZERO rows has NO restriction (every move allowed) — this is the
/// inert default. Once any row exists, a move from→to is allowed only if a row
/// matches (CANCELED is always allowed as an escape hatch; enforced in code).
/// fromStatus/toStatus reuse the TaskStatus enum (the engine stays the enum).
model WorkflowTransition {
  id         String     @id @default(cuid())
  projectId  String
  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fromStatus TaskStatus
  toStatus   TaskStatus
  createdAt  DateTime   @default(now())

  @@unique([projectId, fromStatus, toStatus])
  @@index([projectId])
}

/// Daily point-in-time snapshot of a sprint's remaining work, written by
/// /api/cron/sprint-snapshot. Powers a true historical burndown line (board
/// drags log no per-day history, so the live chart was a current-state
/// projection only). One row per sprint per calendar day (idempotent upsert).
model SprintSnapshot {
  id              String   @id @default(cuid())
  sprintId        String
  sprint          Sprint   @relation(fields: [sprintId], references: [id], onDelete: Cascade)
  /// Calendar day (UTC) this snapshot represents.
  date            DateTime @db.Date
  /// Remaining (not DONE/CANCELED) at snapshot time.
  remainingPoints Int      @default(0)
  remainingTasks  Int      @default(0)
  /// Totals at snapshot time (committed baseline / ideal line).
  totalPoints     Int      @default(0)
  totalTasks      Int      @default(0)
  takenAt         DateTime @default(now())

  @@unique([sprintId, date])
  @@index([sprintId])
}

// ============================================================================
// CRM (org-level sales): Contact, Pipeline, PipelineStage, Deal.
// ADMIN/PM only. Additive + self-contained — no link to Project/Task in v1.
// ============================================================================

enum DealStatus {
  OPEN
  WON
  LOST
}

/// Marks a pipeline stage as a terminal drop-zone. null = NORMAL.
enum StageKind {
  NORMAL
  WON
  LOST
}

/// A CRM contact (person/company). Owner FK SetNull — sales history outlives staff.
model Contact {
  id        String    @id @default(cuid())
  name      String
  email     String?
  phone     String?
  company   String?
  notes     String?   @db.Text
  ownerId   String?
  owner     User?     @relation("ContactOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  deals     Deal[]
  /// Leads that converted into this contact (usually 0–1).
  convertedFromLeads Lead[] @relation("LeadConvertedContact")

  @@index([ownerId])
  @@index([email])
}

/// Space: an org-level folder that GROUPS projects. Additive —
/// projects with spaceId=null are simply ungrouped (today's behavior). v1 does
/// NOT re-root tasks/boards under spaces (that's a future epic) and grants no
/// access by itself; project visibility is unchanged.
model Space {
  id          String    @id @default(cuid())
  name        String
  description String?
  order       Int       @default(0)
  color       String?
  archivedAt  DateTime?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  projects    Project[]

  @@index([archivedAt, order])
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING     // ждём ответа заявителя
  RESOLVED
  CLOSED
}

/// Service-desk ticket. Standalone v1 (NOT a Task) — an agent
/// logs a request from an external/internal requester (free-text). SLA due
/// times are stamped at creation from a per-priority policy; the on-track /
/// breached STATE is derived at render from due times + now (no stored flag).
/// (Future v2 may re-flavor tickets as Task type=REQUEST — see design spec.)
model Ticket {
  id                 String       @id @default(cuid())
  subject            String
  description        String?      @db.Text
  requesterName      String
  requesterEmail     String?
  priority           TaskPriority @default(MEDIUM)
  status             TicketStatus @default(OPEN)
  assigneeId         String?
  assignee           User?        @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  /// SLA targets stamped at creation from the priority policy.
  firstResponseDueAt DateTime?
  resolutionDueAt    DateTime?
  /// Lifecycle stamps — stop the respective SLA clock.
  firstRespondedAt   DateTime?
  resolvedAt         DateTime?
  createdById        String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([status, resolutionDueAt])
  @@index([assigneeId, status])
}

/// A named sales pipeline. "Selected" pipeline is URL state; first-by-order = default.
model Pipeline {
  id          String          @id @default(cuid())
  name        String
  description String?
  order       Int             @default(0)
  archivedAt  DateTime?
  createdById String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  stages      PipelineStage[]
  deals       Deal[]

  @@index([archivedAt, order])
}

/// An ordered stage (column) within a pipeline. kind WON/LOST = terminal.
model PipelineStage {
  id          String     @id @default(cuid())
  pipelineId  String
  pipeline    Pipeline   @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  name        String
  order       Int        @default(0)
  kind        StageKind?
  probability Int?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deals       Deal[]

  @@index([pipelineId, order])
}

/// A sales deal moving through a pipeline's stages.
model Deal {
  id                String        @id @default(cuid())
  title             String
  contactId         String?
  contact           Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  pipelineId        String
  pipeline          Pipeline      @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  stageId           String
  stage             PipelineStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  amount            Decimal?      @db.Decimal(14, 2)
  currency          String        @default("RUB")
  status            DealStatus    @default(OPEN)
  ownerId           String?
  owner             User?         @relation("DealOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  /// Optional link to a delivery Project (org-level sales → delivery handoff).
  /// SetNull: archiving/deleting a project must not destroy sales history.
  projectId         String?
  project           Project?      @relation("DealProject", fields: [projectId], references: [id], onDelete: SetNull)
  lostReason        String?       @db.Text
  expectedCloseDate DateTime?
  closedAt          DateTime?
  createdById       String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  deletedAt         DateTime?
  /// Leads that converted into this deal (usually 0–1).
  convertedFromLeads Lead[]       @relation("LeadConvertedDeal")

  @@index([pipelineId, stageId])
  @@index([ownerId, status])
  @@index([contactId])
  @@index([projectId])
}

/// Lead lifecycle: NEW (top-of-funnel) → CONVERTED (became a Contact[+Deal])
/// or DISQUALIFIED (dead). Convert is one-way and idempotent (see convertLeadAction).
enum LeadStatus {
  NEW
  CONVERTED
  DISQUALIFIED
}

/// A CRM lead: an unqualified inbound before it becomes a Contact/Deal.
/// Soft-deleted (deletedAt). Owner FK SetNull — pipeline history outlives staff.
/// Convert stamps convertedContactId/convertedDealId for an audit trail.
model Lead {
  id        String     @id @default(cuid())
  name      String
  email     String?
  phone     String?
  company   String?
  source    String?
  notes     String?    @db.Text
  status    LeadStatus @default(NEW)
  ownerId   String?
  owner     User?      @relation("LeadOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  /// Audit trail of a one-way convert. SetNull so deleting the resulting
  /// contact/deal never destroys the lead's converted marker.
  convertedContactId String?
  convertedContact   Contact? @relation("LeadConvertedContact", fields: [convertedContactId], references: [id], onDelete: SetNull)
  convertedDealId    String?
  convertedDeal      Deal?    @relation("LeadConvertedDeal", fields: [convertedDealId], references: [id], onDelete: SetNull)
  convertedAt        DateTime?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([status, createdAt])
  @@index([ownerId])
  @@index([email])
}

// ─────────────────────────── Custom roles (RBAC overlay) ───────────────────────────
// Additive + inert: a CustomRole carries an EXPLICIT capability set; when assigned
// (UserCustomRole) it REPLACES the user's UserRole-derived org capabilities, so it can
// both grant (more than MEMBER) and restrict (less than a base role). Users with no
// assignment keep their UserRole baseline verbatim ⇒ deploy changes nothing. Effective
// caps are resolved from the DB per request (lib/capabilities), never carried on the JWT.

enum CustomRoleScope {
  ORG     // v1 writes only this
  PROJECT // reserved for v2; the resolver early-returns null on this value
}

/// An admin-defined role with an explicit capability set (subset of the catalog
/// in apps/web/lib/capabilities/catalog.ts, validated in the action layer).
model CustomRole {
  id           String          @id @default(cuid())
  name         String
  description  String?
  scope        CustomRoleScope @default(ORG)
  /// Complete capability set (text[] of CapabilityKey). Empty = max restrict.
  capabilities String[]        @default([])
  /// The UserRole this role was templated from — drives prefill + the VIEWER
  /// floor clamp. NOT a resolve-time fallback; the cap set is explicit.
  baseRole     UserRole        @default(MEMBER)
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  deletedAt    DateTime?
  createdById  String?
  createdBy    User?           @relation("CustomRoleCreator", fields: [createdById], references: [id], onDelete: SetNull)
  assignments        UserCustomRole[]
  projectAssignments ProjectMemberCustomRole[]

  @@index([scope, isActive])
}

/// Org-level assignment (one per user → REPLACE is unambiguous). Live in v1.
model UserCustomRole {
  id           String     @id @default(cuid())
  userId       String     @unique
  user         User       @relation("UserCustomRoleAssignee", fields: [userId], references: [id], onDelete: Cascade)
  customRoleId String
  customRole   CustomRole @relation(fields: [customRoleId], references: [id], onDelete: Cascade)
  assignedAt   DateTime   @default(now())
  assignedById String?
  assignedBy   User?      @relation("UserCustomRoleAssigner", fields: [assignedById], references: [id], onDelete: SetNull)

  @@index([customRoleId])
}

/// Per-project assignment. RESERVED for v2 — migrated but never written/read in v1.
model ProjectMemberCustomRole {
  id           String     @id @default(cuid())
  projectId    String
  userId       String
  customRoleId String
  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user         User       @relation("ProjectMemberCustomRoleUser", fields: [userId], references: [id], onDelete: Cascade)
  customRole   CustomRole @relation(fields: [customRoleId], references: [id], onDelete: Cascade)
  assignedAt   DateTime   @default(now())

  @@unique([projectId, userId])
  @@index([customRoleId])
}

/// Which view a saved filter targets — board and list have different filter
/// dimensions (board has onlyMine/sprint, list has status/sort/dir).
enum SavedFilterScope {
  BOARD
  LIST
}

/// Named, persisted board/list filter preset. Additive + inert: until a user
/// creates one, every board/list query is byte-identical to today. `query`
/// stores the SAME URL-search-param shape the existing filter bars produce
/// (e.g. "priority=HIGH&q=foo&dueWithin=7&type=BUG&reviewer=me"), so applying a
/// preset is "replay these params" — it never touches the per-stake OR access
/// clause in listTasksForBoard / listTasksForProject.
model SavedFilter {
  id        String           @id @default(cuid())
  /// Owner. A preset is private to its owner unless isShared=true.
  userId    String
  user      User             @relation("SavedFilterOwner", fields: [userId], references: [id], onDelete: Cascade)
  /// Project the preset belongs to (presets are project-scoped).
  projectId String
  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  /// Which surface this preset targets.
  scope     SavedFilterScope
  name      String
  /// Serialized URL query string (params only, no leading "?").
  query     String
  /// When true, every viewer of the project sees this preset (read-only).
  isShared  Boolean          @default(false)
  /// When true, this is the owner's default preset for (scope) in this project,
  /// auto-applied on load when no explicit params are present. Single-default
  /// per (userId, projectId, scope) is enforced in the action layer (CI uses
  /// prisma db push → cannot express a partial unique index).
  isDefault Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([userId, projectId, scope])
  @@index([projectId, isShared])
}

/// A Telegram group or channel whose messages PM wants to turn into tasks.
/// Bot must be added to the chat with Group Privacy disabled so it sees normal messages.
///
/// Each row is owned by exactly one personal bot (`UserTelegramBot`) — the
/// same Telegram chat could in principle be linked through different PMs'
/// bots, hence the composite (botId, telegramChatId) unique key.
model ProjectTelegramChat {
  id             String   @id @default(cuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  botId          String
  bot            UserTelegramBot @relation(fields: [botId], references: [id], onDelete: Cascade)
  /// Telegram chat id as string (e.g. "-1001234567890").
  telegramChatId String
  chatTitle      String?
  linkedByUserId String
  linkedBy       User     @relation("ProjectTelegramLinker", fields: [linkedByUserId], references: [id])
  createdAt      DateTime @default(now())

  ingestMessages TelegramProjectMessage[]

  @@unique([botId, telegramChatId])
  @@index([projectId])
  @@index([botId])
}

/// Personal Telegram bot owned by a single PM. The token is provided by
/// the user via UI (BotFather → /newbot) and stored AES-256-GCM encrypted.
/// The multi-bot runner in apps/tg-bot polls all `isActive=true` rows.
model UserTelegramBot {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Telegram bot user id (returned by getMe). Stable across token rotations.
  botTgId        String   @unique
  botUsername    String
  botName        String?
  /// AES-256-GCM ciphertext: base64( iv | cipher | authTag ).
  encryptedToken String   @db.Text
  isActive       Boolean  @default(true)
  lastPolledAt   DateTime?
  lastError      String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  telegramChats  ProjectTelegramChat[]

  @@index([userId])
  @@index([isActive])
}

// ============================================================================
// MEETINGS — встроенные групповые видеозвонки на LiveKit + транскрипт.
// LiveKit room запускается под уникальным livekitRoomName; egress пишет
// MP4 в MinIO под `meetings/<id>/recording.mp4`. После окончания
// transcribe-worker качает файл, прогоняет через WhisperX (диаризация
// спикеров) + Qwen 14B (саммари + предложения задач).
// ============================================================================

model Meeting {
  id                    String        @id @default(cuid())
  projectId             String?
  project               Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  /// Optional link to a chat channel — set when the meeting was
  /// kicked off via "Позвонить" from a DM/channel. End-of-call
  /// summary card is posted back into this channel.
  channelId             String?
  channel               Channel?      @relation("ChannelMeeting", fields: [channelId], references: [id], onDelete: SetNull)
  title                 String
  status                MeetingStatus @default(PLANNED)
  kind                  MeetingKind   @default(VIDEO_LIVEKIT)

  /// Unique LiveKit room name (cuid). Used to mint JWT for participants
  /// and to instruct egress which room to record.
  livekitRoomName       String?       @unique
  /// Egress job id returned by LiveKit when recording starts.
  livekitEgressId       String?
  /// MinIO/S3 object key for the composite mp4.
  recordingKey          String?
  recordingDurationSec  Int?

  startedAt             DateTime?
  endedAt               DateTime?
  /// Last error from transcribe-worker (status === FAILED).
  processingError       String?       @db.Text

  createdById           String
  createdBy             User          @relation("MeetingCreator", fields: [createdById], references: [id])

  participants          MeetingParticipant[]
  invites               MeetingInvite[]
  transcript            MeetingTranscript?

  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([projectId, status, createdAt])
  @@index([createdById, createdAt])
}

enum MeetingStatus {
  PLANNED       // создана, ещё не начата
  ACTIVE        // идёт сейчас (egress пишет)
  ENDED         // закончилась, в очереди на обработку
  PROCESSING    // транскрибируется + AI-анализ
  READY         // готово, можно открывать карточку
  FAILED        // ошибка обработки (см. processingError)
}

enum MeetingKind {
  VIDEO_LIVEKIT     // встроенный LiveKit room
  TG_VOICE_BATCH    // batch транскрипт голосовых из TG-чата
}

model MeetingParticipant {
  id                String    @id @default(cuid())
  meetingId         String
  meeting           Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  /// null when participant is an external guest joined via invite link.
  userId            String?
  user              User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  /// LiveKit identity, unique per room. For internal users: "user:<id>";
  /// for guests: "guest:<random>".
  livekitIdentity   String
  displayName       String
  joinedAt          DateTime  @default(now())
  leftAt            DateTime?

  @@unique([meetingId, livekitIdentity])
  @@index([userId, joinedAt])
}

/// Shareable join link for external guests who don't have a giper-pm
/// account. The token is the secret in the URL (https://pm.../m/<token>);
/// hitting that URL shows a "введите имя" page and mints a guest-scope
/// LiveKit JWT. Tokens are expirable, revocable, and capped by use count
/// so a leaked link doesn't permanently expose the room.
model MeetingInvite {
  id            String    @id @default(cuid())
  meetingId     String
  meeting       Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  /// Long random secret carried in the URL. Indexed @unique so lookup
  /// is O(1) on every guest hit.
  token         String    @unique
  createdById   String
  createdBy     User      @relation("MeetingInviteCreator", fields: [createdById], references: [id])
  createdAt     DateTime  @default(now())
  /// Hard expiry — defaults to 24h after createdAt in app code. Past
  /// expiresAt the landing page refuses to mint a token.
  expiresAt     DateTime
  /// Manually revoked by an admin or the creator. Independent from
  /// expiresAt so we can kill a token before its TTL runs out.
  revokedAt     DateTime?
  /// Optional cap on how many distinct guests can claim this link.
  /// null = unlimited within expiresAt.
  maxUses       Int?
  /// Incremented atomically each time a guest claims a session.
  usedCount     Int       @default(0)

  @@index([meetingId, revokedAt])
}

model MeetingTranscript {
  id          String    @id @default(cuid())
  meetingId   String    @unique
  meeting     Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  /// Concatenated plain text of all segments (for full-text search).
  fullText    String    @db.Text
  /// JSON array of { start, end, speaker, text }.
  segments    Json
  /// AI-generated meeting summary in Russian (decisions, action items,
  /// open questions). May be null while still PROCESSING.
  summary     String?   @db.Text
  /// Manual SPEAKER_xx → person mapping. WhisperX diarization labels
  /// segments with auto-generated SPEAKER_00, SPEAKER_01, … which are
  /// stable per-transcript but mean nothing semantic. This map lets a
  /// PM/creator pin "SPEAKER_00 = Иван (userId)" or a free-form name.
  /// Shape: { SPEAKER_00: { userId?: string|null, name: string } }.
  /// Unmapped speakers render as «Спикер N» in the UI.
  speakerMap  Json?
  model       String?   // e.g. "large-v3"
  language    String?   // ISO code detected by Whisper
  createdAt   DateTime  @default(now())
}

model TelegramProjectMessage {
  id             String              @id @default(cuid())
  linkId         String
  link           ProjectTelegramChat @relation(fields: [linkId], references: [id], onDelete: Cascade)
  telegramChatId String
  messageId      Int
  fromTgUserId   String?
  fromUsername   String?
  text           String              @db.Text
  /// Files attached to the original Telegram message. JSON array of
  /// { telegramFileId, fileName, mimeType, sizeBytes }. Files are NOT
  /// downloaded at ingest time — only when a PM creates a task that
  /// references this message via the AI harvest flow.
  attachments    Json?
  capturedAt     DateTime            @default(now())
  harvestedAt    DateTime?

  @@unique([telegramChatId, messageId])
  @@index([linkId, harvestedAt, capturedAt])
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

model ProjectMember {
  id          String      @id @default(cuid())
  projectId   String
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        MemberRole  @default(CONTRIBUTOR)
  addedAt     DateTime    @default(now())

  @@unique([projectId, userId])
  @@index([userId])
}

/// Membership mirrored from the upstream Bitrix sonet_group.
///
/// Separate from ProjectMember on purpose:
///   - ProjectMember is *our* internal team-role assignment (LEAD,
///     CONTRIBUTOR, REVIEWER, OBSERVER) and may be edited inside
///     giper-pm independently of Bitrix.
///   - ProjectBitrixMember is the read-only mirror of who is actually
///     in the Bitrix workgroup. It's the source of truth for
///     visibility decisions ("can this user see the project") so a
///     user added to the Bitrix group sees the project the moment we
///     sync, even before they have a single task assigned to them.
///
/// We store bitrixUserId raw; userId is the local link when we can
/// resolve them (most users do have it via syncUsers). Rows with a
/// null userId still help backfill once the user is created.
model ProjectBitrixMember {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  bitrixUserId  String
  /// Resolved local user. Nullable because the upstream Bitrix
  /// member may not yet exist as a giper-pm user (long-tail of
  /// external contractors etc). Sync re-resolves on every run.
  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  /// "A" = owner, "E" = moderator, "K" = user, "B" = ban (per Bitrix).
  /// We don't enforce semantics here — just mirror so future filters
  /// can use the role if needed.
  role          String?
  syncedAt      DateTime @default(now())

  @@unique([projectId, bitrixUserId])
  @@index([userId])
  @@index([projectId])
}

enum MemberRole {
  LEAD          // PM проекта
  CONTRIBUTOR   // активный участник
  REVIEWER      // только ревью
  OBSERVER      // read-only
}

model Task {
  id            String       @id @default(cuid())
  number        Int          // порядковый в проекте, для key типа "GFM-42"
  projectId     String
  project       Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title         String
  description   String?      @db.Text
  status        TaskStatus   @default(BACKLOG)
  priority      TaskPriority @default(MEDIUM)
  type          TaskType     @default(TASK)
  
  assigneeId    String?
  assignee      User?        @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creatorId     String
  creator       User         @relation("TaskCreator", fields: [creatorId], references: [id])
  // Optional REVIEW gate — if set and != assignee, only this user can
  // close the task by moving REVIEW → DONE. Without a reviewer the task
  // works the old way (anyone with edit can close).
  reviewerId    String?
  reviewer      User?        @relation("TaskReviewer", fields: [reviewerId], references: [id])

  parentId      String?
  parent        Task?        @relation("TaskSubtasks", fields: [parentId], references: [id])
  subtasks      Task[]       @relation("TaskSubtasks")
  
  estimateHours Decimal?     @db.Decimal(8, 2)
  /// Relative size / story points (distinct from time estimate).
  storyPoints   Int?
  dueDate       DateTime?
  startedAt     DateTime?    // когда впервые ушло в IN_PROGRESS
  completedAt   DateTime?    // когда ушло в DONE
  /// Mandatory result/итог captured when the task is closed (internalStatus →
  /// DONE). Pushed to Bitrix as a comment + native task Result for mirrors.
  completionResult String?   @db.Text

  tags          String[]     @default([])
  
  // Внешние идентификаторы для синка
  externalId    String?      // ID в Bitrix24/Jira
  externalSource String?     // "bitrix24" / "jira" / null

  // Two-way sync bookkeeping (Bitrix24).
  bitrixSyncedAt   DateTime?
  bitrixSyncedHash String?
  syncConflict     Boolean   @default(false)

  // Upstream Bitrix24 actor ids — preserved verbatim so the read-only
  // mirror panel can always render the real upstream creator/assignee,
  // even when the matching local User row hasn't been resolved yet
  // (e.g. Bitrix users without an EMAIL that syncUsers used to skip).
  bitrixCreatedById   String?
  bitrixResponsibleId String?

  // Upstream Bitrix24 PARENT_ID, preserved verbatim. The local `parentId`
  // self-relation is resolved from this in a second pass (relinkBitrixParents)
  // because a child can sync before its parent exists locally. Kept so the
  // link can always be (re)derived without re-fetching from Bitrix.
  bitrixParentId      String?

  // For Bitrix24 tasks whose discussion lives in the IM messenger
  // (modern "collab" mode and any task migrated to the new chat-based
  // discussion model). When set, comment sync uses
  // im.dialog.messages.get with DIALOG_ID=`chat<chatId>` instead of
  // the legacy task.commentitem.getlist endpoint — that's the only
  // way to see comments on these tasks.
  bitrixChatId        String?

  // Internal track — independent from the Bitrix-mirror status above.
  // The mirrored `status` reflects what the client sees in Bitrix; the
  // internal track is what our team uses day-to-day. Defaults match
  // the mirror so non-mirrored tasks behave the old way.
  internalStatus  TaskStatus  @default(BACKLOG)

  // --- Board placement (Phase 0). Nullable during rollout,
  // backfilled from internalStatus. `columnId` is the configurable board
  // column the card sits in; `boardRank` is a fractional sort key for stable
  // drag-ordering within a (column, swimlane) cell.
  columnId      String?
  column        BoardColumn?   @relation(fields: [columnId], references: [id], onDelete: SetNull)
  swimlaneId    String?
  swimlane      BoardSwimlane? @relation(fields: [swimlaneId], references: [id], onDelete: SetNull)
  boardRank     String?
  /// Sub-column (sub-stage) the card sits in within its column.
  subColumnId   String?
  subColumn     BoardSubColumn? @relation(fields: [subColumnId], references: [id], onDelete: SetNull)

  /// Sprint the card is committed to. Nullable = backlog.
  /// SetNull on sprint delete → card returns to backlog, never deleted.
  sprintId      String?
  sprint        Sprint?        @relation(fields: [sprintId], references: [id], onDelete: SetNull)

  /// Release/version the card is slated for (Jira fixVersion). Nullable = none.
  /// SetNull on version delete → card keeps existing, just unversioned.
  versionId     String?
  version       Version?       @relation(fields: [versionId], references: [id], onDelete: SetNull)

  /// Component (product area) the card belongs to (Jira component). Nullable.
  /// SetNull on component delete → card keeps existing, just uncategorized.
  componentId   String?
  component     Component?     @relation(fields: [componentId], references: [id], onDelete: SetNull)

  /// Card cover. Either an uploaded image (S3 object key,
  /// served via /api/covers/[taskId]) or a solid colour (hex). At most one
  /// is set; both null = no cover (card renders as before).
  coverImageKey String?
  coverColor    String?

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  timeEntries   TimeEntry[]
  comments      Comment[]
  statusChanges TaskStatusChange[]
  attachments   Attachment[]
  watchers      TaskWatcher[]
  checklists    Checklist[]
  blocks        TaskDependency[] @relation("BlocksFrom")
  blockedBy     TaskDependency[] @relation("BlocksTo")
  pullRequests  TaskPullRequest[]
  designs       TaskDesign[]
  assignments   TaskAssignment[]
  kaitenSuggAsKaiten KaitenMatchSuggestion[] @relation("KaitenSuggKaiten")
  kaitenSuggAsBitrix KaitenMatchSuggestion[] @relation("KaitenSuggBitrix")
  // Native tag system (separate from the legacy `tags String[]` mirror
  // of Bitrix24 TAGS payloads above).
  taskTags      TaskTag[]
  /// Custom field values set on this task (Phase 3).
  customFieldValues CustomFieldValue[]

  @@unique([projectId, number])
  @@index([assigneeId, status])
  @@index([projectId, status])
  @@index([projectId, internalStatus])
  @@index([sprintId, internalStatus])
  @@index([versionId])
  @@index([componentId])
  @@index([dueDate])
  @@index([columnId, swimlaneId])
  @@index([parentId])
  @@index([externalSource, bitrixParentId])
  // Hot path for mirror upserts (Kaiten/Bitrix) — find a task by its external id
  // within a project. Non-unique: prod has pre-existing duplicate external tuples.
  @@index([projectId, externalSource, externalId])
}

/// Configurable kanban column for a project board. Maps to the
/// internal task track (one column per TaskStatus to start) so reports, the
/// Bitrix mirror, and existing status logic keep working while the board
/// becomes user-orderable with per-column WIP limits. (Phase 0)
model BoardColumn {
  id        String     @id @default(cuid())
  projectId String
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  /// The internal-status bucket this column represents.
  status    TaskStatus
  /// Left → right display order.
  order     Int
  /// WIP limit on card count. null = no limit. Phase 1 adds size-based + hard enforcement.
  wipLimit  Int?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  tasks     Task[]
  subColumns BoardSubColumn[]

  @@unique([projectId, status])
  @@index([projectId, order])
}

/// Sub-column (sub-stage) inside a BoardColumn. A column with one
/// or more sub-columns splits into ordered child lanes; a card then sits in a
/// leaf sub-column. Columns with no sub-columns behave exactly as before.
model BoardSubColumn {
  id        String      @id @default(cuid())
  columnId  String
  column    BoardColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)
  name      String
  /// Left → right display order within the parent column.
  order     Int
  /// WIP limit on card count for this sub-column. null = no limit.
  wipLimit  Int?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  tasks     Task[]

  @@unique([columnId, name])
  @@index([columnId, order])
}

/// Horizontal swimlane ("дорожка") on a project board. (Phase 0)
model BoardSwimlane {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  order     Int
  wipLimit  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tasks     Task[]

  @@index([projectId, order])
}

// Linked-list of small actionable items inside a task. A task may have
// multiple checklists ("Definition of Done" + "QA" is a common case).
model Checklist {
  id        String          @id @default(cuid())
  taskId    String
  task      Task            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  title     String          @default("Чек-лист")
  // order within the task — lower = top.
  order     Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  items     ChecklistItem[]

  @@index([taskId, order])
}

model ChecklistItem {
  id          String    @id @default(cuid())
  checklistId String
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  body        String
  isDone      Boolean   @default(false)
  // order within the checklist — lower = top.
  order       Int       @default(0)
  // Audit: who and when checked it. Cleared on uncheck.
  doneById    String?
  doneAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([checklistId, order])
}

// "from blocks to" — the source task must reach DONE/CANCELED before
// the target task can move to IN_PROGRESS without a warning.
// We only persist BLOCKS edges; "blockedBy" is the inverse relation.
// Cycles are prevented at the action layer with a DFS check; the
// schema unique constraint catches duplicate edges.
/// Type of a directed task↔task link. BLOCKS is the original (and default, so
/// existing rows stay blockers): `from` blocks `to`. RELATES_TO is a soft,
/// non-blocking association; DUPLICATES means `from` duplicates `to`. ONLY
/// BLOCKS participates in the board's blocked-state / auto-unblock / Gantt-arrow
/// / cycle logic — the others are display-only relations.
enum TaskLinkType {
  BLOCKS
  RELATES_TO
  DUPLICATES
}

model TaskDependency {
  id          String       @id @default(cuid())
  fromTaskId  String
  fromTask    Task         @relation("BlocksFrom", fields: [fromTaskId], references: [id], onDelete: Cascade)
  toTaskId    String
  toTask      Task         @relation("BlocksTo", fields: [toTaskId], references: [id], onDelete: Cascade)
  /// Link kind. Defaults to BLOCKS so every pre-existing edge stays a blocker.
  linkType    TaskLinkType @default(BLOCKS)
  createdAt   DateTime     @default(now())
  createdById String

  @@unique([fromTaskId, toTaskId, linkType])
  @@index([toTaskId])
}

// A medium-confidence Kaiten↔Bitrix title match (below the auto-link threshold)
// awaiting human review. Accepting it creates a DUPLICATES TaskDependency;
// rejecting it suppresses the pair so re-syncs don't keep re-proposing it.
model KaitenMatchSuggestion {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  kaitenTaskId String
  kaitenTask   Task     @relation("KaitenSuggKaiten", fields: [kaitenTaskId], references: [id], onDelete: Cascade)
  bitrixTaskId String
  bitrixTask   Task     @relation("KaitenSuggBitrix", fields: [bitrixTaskId], references: [id], onDelete: Cascade)
  score        Float
  status       String   @default("pending") // pending | accepted | rejected
  createdAt    DateTime @default(now())
  decidedAt    DateTime?
  decidedById  String?

  @@unique([kaitenTaskId, bitrixTaskId])
  @@index([projectId, status])
}

// Linkage between a task and a GitHub pull request. Webhook-fed: when
// a PR title/body/branch contains a `KEY-N` reference we ensure a row
// exists; subsequent webhook events (synchronize, review, merge, close)
// update the same row by (repo, number) — that pair is unique per PR.
//
// We keep the bare metadata we need to render a status badge on the
// task page (state, mergedAt, url). For richer GH metadata (CI checks,
// reviewers) we'd add a polling worker — out of scope for v1.
model TaskPullRequest {
  id        String          @id @default(cuid())
  taskId    String
  task      Task            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  // Source forge: "github" (PR) or "gitlab" (MR). Drives the label/icon
  // on the task page. Defaults to github so existing rows stay correct.
  provider  String          @default("github")
  // GitHub: "owner/repo" (full_name). GitLab: "group/project"
  // (path_with_namespace).
  repo      String
  // PR/MR number within the repo. GitHub PR number; GitLab MR iid.
  number    Int
  title     String
  state     PullRequestState @default(OPEN)
  // PR/MR URL — clickable on the task page.
  url       String
  // Branches: head = source, base = target.
  headRef   String?
  baseRef   String?
  authorLogin String?
  mergedAt  DateTime?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([repo, number, taskId])
  @@index([taskId])
  @@index([repo, number])
}

/// A Figma design linked to a task. Mirrors TaskPullRequest's shape — a task
/// can have several. v1 stores the link + parsed file/node for embedding;
/// thumbnailUrl is filled later by the Figma API (token) slice.
model TaskDesign {
  id           String   @id @default(cuid())
  taskId       String
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  provider     String   @default("figma")
  /// Canonical Figma URL (file or a specific node/frame).
  url          String
  /// Figma file key parsed from the URL.
  fileKey      String
  /// Optional node/frame id (…?node-id=1-23 → "1:23"). Null = whole file.
  nodeId       String?
  /// Display title — from the URL slug, refined later via the Figma API.
  title        String
  /// Frame/file thumbnail — populated by the Figma API slice (null until then).
  thumbnailUrl String?
  addedById    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([taskId, url])
  @@index([taskId])
  @@index([fileKey])
}

/// Org-level Figma connection (single row). Holds an encrypted Figma personal
/// access token used to fetch frame thumbnails, private files and comments.
/// Mirrors RepoConnection's token handling (tgTokenCrypto + masked hint).
model FigmaConnection {
  id          String   @id @default(cuid())
  /// Enforces exactly one connection row.
  singleton   String   @unique @default("figma")
  tokenEnc    String
  tokenHint   String
  status      String   @default("active") // 'active' | 'error'
  lastError   String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// In-app GitHub/GitLab repository connection for a project. The admin pastes
/// a repo URL + access token; the server validates it, auto-creates the webhook
/// on the forge (secret = our GITHUB/GITLAB_WEBHOOK_SECRET so existing webhook
/// routes keep working), and stores the (encrypted) token for management +
/// backfill. PR/MR linkage itself is unchanged: by KEY-N reference.
model RepoConnection {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  provider    String   // 'github' | 'gitlab'
  // GitHub: "owner/repo". GitLab: "group/project" (path_with_namespace).
  repo        String
  // Forge base URL (self-hosted GitLab). null → public host.
  baseUrl     String?
  // AES-256-GCM access token (reuses tgTokenCrypto) + masked last-4 for UI.
  tokenEnc    String
  tokenHint   String
  // Provider's webhook id, kept so we can delete it on disconnect.
  webhookId   String?
  status      String   @default("active") // 'active' | 'error'
  lastError   String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([provider, repo, projectId])
  @@index([projectId])
}

enum PullRequestState {
  OPEN
  CLOSED
  MERGED
  DRAFT
}

// Subscription record: when a user toggles "watch" on a task they get
// pinged on subsequent comments / status changes the same way assignee
// and creator are. Assignee/creator are NOT stored here — they're
// always-watchers by definition; the fan-out logic dedupes on userId.
model TaskWatcher {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([taskId, userId])
  @@index([userId])
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  REVIEW
  BLOCKED
  DONE
  CANCELED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskType {
  TASK
  BUG
  FEATURE
  EPIC          // контейнер для подзадач
  CHORE         // рутина, не имеет бизнес-значения
}

model TaskStatusChange {
  id          String     @id @default(cuid())
  taskId      String
  task        Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  fromStatus  TaskStatus?
  toStatus    TaskStatus
  changedById String
  changedAt   DateTime   @default(now())
  
  @@index([taskId, changedAt])
}

model Comment {
  id          String    @id @default(cuid())
  taskId      String
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId    String
  author      User      @relation(fields: [authorId], references: [id])
  body        String    @db.Text
  source      CommentSource @default(WEB)

  // EXTERNAL: pushed to the source-of-truth (Bitrix24 etc.) and visible to
  // the client. INTERNAL: stays in our system only — useful for technical
  // notes the team writes about a task ("hack here, refactor later") that
  // the client shouldn't see.
  visibility  CommentVisibility @default(EXTERNAL)

  // Outbound bookkeeping. When we successfully push an EXTERNAL comment to
  // Bitrix we store the remote id here so subsequent edits/deletes target
  // the right record (and so we can dedupe if the user re-saves).
  externalId     String?
  externalSource String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([taskId, createdAt])
  @@unique([externalSource, externalId])
}

enum CommentVisibility {
  EXTERNAL
  INTERNAL
}

enum CommentSource {
  WEB
  TELEGRAM
  EMAIL
  GITHUB        // авто-комментарий от коммита/PR
  GITLAB        // авто-комментарий от коммита/MR
  SLACK
}

model Attachment {
  id          String    @id @default(cuid())
  taskId      String
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  filename    String
  mimeType    String
  sizeBytes   Int
  // S3 / R2 object key. Set for locally-uploaded files AND for mirrored sources
  // we download into our own bucket (Kaiten). Left empty for sources we proxy at
  // request time from live credentials (Bitrix24 rebuilds the URL via webhook).
  storageKey  String
  uploadedById String?
  uploadedAt  DateTime  @default(now())

  // Read-only mirror (Bitrix24): which external system this file lives in
  // and the attachedObject id we use to query metadata + download URL.
  externalSource String?
  externalId     String?

  @@unique([externalSource, externalId])
  @@index([taskId])
}

// ============================================================================
// TIME TRACKING
// ============================================================================

model TimeEntry {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId      String?
  task        Task?          @relation(fields: [taskId], references: [id], onDelete: SetNull)
  
  startedAt   DateTime
  endedAt     DateTime?      // null = таймер ещё идёт
  durationMin Int?           // вычисляется при stop, null пока идёт
  
  source      TimeSource
  category    ActivityCategory? // для авто/digital — категория
  note        String?        @db.Text
  
  // Для digital-источников
  externalRef String?        // commit SHA, PR ID, calendar event ID
  
  // Сверка
  isReconciled Boolean       @default(false)
  flag         TimeFlag?
  
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([userId, startedAt])
  @@index([taskId])
  @@index([source, startedAt])
}

enum TimeSource {
  MANUAL_TIMER     // живой live timer
  MANUAL_FORM      // ручной ввод задним числом
  TELEGRAM         // через бота
  AUTO_AGENT       // от desktop-агента
  AUTO_BROWSER     // от браузерного расширения
  DIGITAL_GIT      // из коммита/PR
  DIGITAL_CALENDAR // из календарного события
  DIGITAL_SLACK    // из активности в Slack
}

enum TimeFlag {
  REVIEW_NEEDED        // расхождение manual vs auto > 30%
  GAP_DETECTED         // дырка в дне сотрудника
  OVERLAPPING          // два таймера пересекаются
  EXCESSIVE            // > 12 часов в день
  IDLE_LOGGED          // юзер залогировал время в период idle
  AUTO_STOPPED         // таймер закрыт системой по лимиту (см. timeLimits.ts)
}

// Сырые данные от агента и расширения. Агрегируются в TimeEntry.
model Activity {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId    String
  device      AgentDevice      @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  
  capturedAt  DateTime
  durationSec Int              // длительность семпла, обычно 30
  
  appName     String?          // "Code", "Chrome", "Slack"
  windowTitle String?          // тайтл окна (или title вкладки)
  url         String?          // только для браузерного семпла
  domain      String?          // host из URL
  
  idleSeconds Int              @default(0)  // сколько из durationSec был idle
  category    ActivityCategory?
  
  // Auto-detected ссылка на задачу
  detectedTaskId String?
  
  createdAt   DateTime         @default(now())
  
  @@index([userId, capturedAt])
  @@index([deviceId, capturedAt])
}

enum ActivityCategory {
  CODING
  DESIGN
  WRITING
  COMMUNICATION    // Slack, email, TG
  MEETING          // Zoom, Meet, Teams
  RESEARCH         // браузер с docs/Stack Overflow
  BROWSING         // нерелевантный браузинг
  IDLE
  PERSONAL         // явно помеченное юзером личное время
  UNKNOWN
}

model Screenshot {
  id          String       @id @default(cuid())
  deviceId    String
  device      AgentDevice  @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  capturedAt  DateTime
  storageKey  String       // S3 key
  blurred     Boolean      @default(false)
  thumbKey    String?      // превью
  
  // Auto-delete через 30 дней (cron job)
  expiresAt   DateTime
  
  createdAt   DateTime     @default(now())
  
  @@index([deviceId, capturedAt])
  @@index([expiresAt])  // для cron очистки
}

// ============================================================================
// INTEGRATIONS
// ============================================================================

model Integration {
  id          String         @id @default(cuid())
  kind        IntegrationKind
  name        String         // человекочитаемое имя инстанса
  config      Json           // зависит от kind
  isActive    Boolean        @default(true)
  
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  projectLinks ProjectIntegration[]
  userLinks    UserIntegrationLink[]
  syncLogs     IntegrationSyncLog[]
  
  @@unique([kind, name])
}

enum IntegrationKind {
  GITHUB
  GITLAB
  BITRIX24
  JIRA
  SLACK
  GOOGLE_CALENDAR
  FIGMA
  TELEGRAM
  TEAMLY
  KAITEN
}

model ProjectIntegration {
  id            String       @id @default(cuid())
  projectId     String
  project       Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  integrationId String
  integration   Integration  @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  externalId    String       // GitHub repo, Bitrix24 group ID, Jira project key
  config        Json?        // override-настройки для этой связки
  
  @@unique([projectId, integrationId, externalId])
}

model UserIntegrationLink {
  id            String       @id @default(cuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  integrationId String
  integration   Integration  @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  externalId    String       // github username, bitrix user id, slack member id
  accessToken   String?      // OAuth-токен юзера, шифрованный
  refreshToken  String?
  
  @@unique([userId, integrationId])
}

model IntegrationSyncLog {
  id            String       @id @default(cuid())
  integrationId String
  integration   Integration  @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  direction     SyncDirection
  startedAt     DateTime     @default(now())
  finishedAt    DateTime?
  status        SyncStatus
  itemsProcessed Int         @default(0)
  errors        Json?
  
  @@index([integrationId, startedAt])
}

enum SyncDirection {
  IN
  OUT
  WEBHOOK
}

enum SyncStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

// ============================================================================
// AUDIT & NOTIFICATIONS
// ============================================================================

model AuditLog {
  id          String     @id @default(cuid())
  userId      String?
  user        User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  entity      String     // "Task", "TimeEntry", "Project"
  entityId    String
  action      String     // "create", "update", "delete", "status_change"
  diff        Json?      // before/after для update
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime   @default(now())
  
  @@index([entity, entityId])
  @@index([userId, createdAt])
}

model Notification {
  id          String              @id @default(cuid())
  userId      String
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind        NotificationKind
  title       String
  body        String?             @db.Text
  link        String?             // относительный путь в приложении
  payload     Json?               // зависит от kind
  
  isRead      Boolean             @default(false)
  readAt      DateTime?
  
  // Каналы доставки
  sentEmail     Boolean           @default(false)
  sentTelegram  Boolean           @default(false)
  
  createdAt   DateTime            @default(now())

  @@index([userId, isRead, createdAt])
}

/// Per-user, per-kind in-app notification preference. A row with inApp=false
/// mutes that NotificationKind for the user (createNotification skips it).
/// Missing row = default (delivered). Notification settings.
model NotificationPreference {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      NotificationKind
  /// Deliver this kind to the in-app inbox / bell. false = muted.
  inApp     Boolean          @default(true)
  updatedAt DateTime         @updatedAt

  @@unique([userId, kind])
  @@index([userId])
}

enum NotificationKind {
  TASK_ASSIGNED
  TASK_COMMENTED
  TASK_STATUS_CHANGED
  TIME_DISCREPANCY        // PM-у при расхождении
  TIME_CONFIRMATION       // юзеру в конце дня
  DEADLINE_APPROACHING
  DEADLINE_PASSED
  MENTION
  CHAT_MENTION            // упоминание в мессенджере
  CHAT_DM                 // личное сообщение / GROUP_DM
  CALL_INVITE             // "X зовёт на звонок"
  SYSTEM
}

// ============================================================================
// TAGS (per-project, with colors). The legacy Task.tags String[] field
// stays as a flat read-only mirror of Bitrix24's TAGS payload; native
// app tagging goes through Tag + TaskTag with referential integrity,
// rename support, and per-project scoping.
// ============================================================================

model Tag {
  id        String    @id @default(cuid())
  projectId String
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  // Slug used for URLs and external-id matching. Lowercase, no spaces.
  slug      String
  // Tailwind-friendly hex string e.g. "#3b82f6"; the UI maps it to a
  // background+text pair.
  color     String    @default("#94a3b8")
  // For future: read-only tags pulled from external system kept apart
  // from native ones (`externalSource = 'bitrix24'` etc).
  externalSource String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tasks     TaskTag[]

  @@unique([projectId, slug])
  @@index([projectId, name])
}

model TaskTag {
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tagId     String
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())
  assignedById String?
  assignedBy User?    @relation("TaskTagAssigner", fields: [assignedById], references: [id])

  @@id([taskId, tagId])
  @@index([tagId])
}

// ============================================================================
// MESSENGER (channels, threads, reactions, mentions, full-text search).
// Discord/Slack-style: every conversation is a Channel; DMs and group-DMs
// are Channel.kind=DM/GROUP_DM with explicit members. Threads use
// Message.parentId (one level deep — replies in a thread reply to the
// thread root, not to each other).
//
// Search: Message.searchVector is a tsvector populated by trigger,
// indexed via GIN. Created in raw SQL inside the migration.
// ============================================================================

model Channel {
  id          String        @id @default(cuid())
  kind        ChannelKind   @default(PUBLIC)
  // Slug is unique inside a project (or globally when projectId is null).
  // For DM/GROUP_DM the slug is auto-generated from member ids and not
  // surfaced in the URL.
  slug        String
  name        String
  description String?       @db.Text
  // Org-wide channel when null; per-project when set.
  projectId   String?
  project     Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  // For PRIVATE/DM/GROUP_DM only members can read; for PUBLIC anyone in
  // the org can join. ARCHIVED hides from sidebar but keeps history.
  isArchived  Boolean       @default(false)
  createdById String
  createdBy   User          @relation("ChannelCreator", fields: [createdById], references: [id])

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  members     ChannelMember[]
  messages    Message[]
  /// Meetings started from this channel via "Позвонить".
  meetings    Meeting[]       @relation("ChannelMeeting")
  /// Invite links — Telegram-style join via /i/<token>.
  invites     ChannelInvite[]

  @@unique([projectId, slug])
  @@index([kind, isArchived])
}

enum ChannelKind {
  PUBLIC      // discoverable, joinable by anyone in the org
  PRIVATE     // invite-only
  DM          // exactly 2 members; auto-created on first DM
  GROUP_DM    // 3+ members, named optionally
  BROADCAST   // org-wide readable, only channel ADMINs may post (announcements)
}

model ChannelMember {
  channelId   String
  channel     Channel    @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId      String
  user        User       @relation("ChannelMembership", fields: [userId], references: [id], onDelete: Cascade)
  // Per-channel role — admin can rename/archive, member can post/read.
  role        ChannelRole @default(MEMBER)
  // For unread badges + "mark all as read".
  lastReadAt  DateTime?
  // Suppress notifications without leaving the channel.
  isMuted     Boolean    @default(false)
  joinedAt    DateTime   @default(now())

  @@id([channelId, userId])
  @@index([userId, lastReadAt])
}

enum ChannelRole {
  ADMIN
  MEMBER
}

/// Invite links for PRIVATE channels. PUBLIC channels don't need
/// them (anyone in the org can join), DM/GROUP_DM are explicit
/// member sets. Tokens are URL-safe random strings; the join URL is
/// /i/<token>. Optional expiry + max uses mirror Telegram semantics.
model ChannelInvite {
  id          String    @id @default(cuid())
  channelId   String
  channel     Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  token       String    @unique
  createdById String
  createdBy   User      @relation("ChannelInviteCreator", fields: [createdById], references: [id])
  /// null = no expiry.
  expiresAt   DateTime?
  /// null = unlimited uses.
  maxUses     Int?
  useCount    Int       @default(0)
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([channelId, revokedAt])
}

model Message {
  id          String     @id @default(cuid())
  channelId   String
  channel     Channel    @relation(fields: [channelId], references: [id], onDelete: Cascade)
  authorId    String
  author      User       @relation("MessageAuthor", fields: [authorId], references: [id])
  // Thread root reference. NULL = top-level message in the channel;
  // non-null = reply inside a thread keyed by the root message.
  parentId    String?
  parent      Message?   @relation("MessageThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies     Message[]  @relation("MessageThread")

  body        String     @db.Text
  // Lightweight markdown-style flag set so the renderer knows whether
  // to allow code blocks / link previews / etc. Default WEB.
  source      MessageSource @default(WEB)
  // Read-only mirror provenance (Bitrix24 collab group chat) + outbound dedupe.
  // externalId scheme: `bxchat:<bitrix message id>`. NULLs are distinct in
  // Postgres so locally-authored messages never collide.
  externalSource String?
  externalId     String?
  /// Optional discriminator for service messages (source=SYSTEM).
  /// Lets the renderer pick a custom card per event type (call
  /// started, member joined, channel renamed, etc.) without forcing
  /// every system message to use the same body-string shape.
  eventKind   MessageEventKind?
  /// Payload for the event card — e.g. { meetingId, livekitRoomName }
  /// for a CALL_STARTED. Free-form JSON keeps the schema stable as
  /// we add new event types.
  eventPayload Json?
  editedAt    DateTime?
  deletedAt   DateTime?
  /// Pinned by a channel ADMIN. Null = not pinned. Sorted by
  /// pinnedAt desc for the "pinned" list, but in the main feed
  /// pinned messages stay in their original chronological place.
  pinnedAt    DateTime?
  pinnedById  String?

  // Cached counts kept in sync by triggers / app code so the channel
  // list can show "12 replies" without a sub-query per row.
  replyCount  Int        @default(0)

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  reactions   MessageReaction[]
  mentions    MessageMention[]
  attachments MessageAttachment[]

  @@unique([externalSource, externalId])
  @@index([channelId, createdAt])
  @@index([parentId, createdAt])
  @@index([authorId])
  /// Partial index conceptually — Postgres doesn't get a WHERE in
  /// Prisma's @@index DSL, but the b-tree includes nulls cheaply
  /// and `WHERE pinnedAt IS NOT NULL ORDER BY pinnedAt DESC` is
  /// our only query against this column.
  @@index([channelId, pinnedAt])
}

model MessageAttachment {
  id          String   @id @default(cuid())
  messageId   String
  message     Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  filename    String
  mimeType    String
  sizeBytes   Int
  // S3-compatible (MinIO in prod) object key.
  storageKey  String
  // Discriminator: FILE is the generic attachment, VIDEO_NOTE is the
  // round-mask short video recorded inline in the composer.
  // AUDIO_NOTE / IMAGE / etc. will land here as we add them.
  kind        MessageAttachmentKind @default(FILE)
  // Only set for VIDEO_NOTE / AUDIO_NOTE: duration in whole seconds.
  // Hard-capped at 60 at write time so the client can't smuggle a
  // 2-hour "video note".
  durationSec Int?
  /// Pixel dimensions for visual attachments (VIDEO_NOTE/IMAGE).
  /// Used by the player to set aspect-ratio so the layout doesn't
  /// shift after the first frame loads.
  width       Int?
  height      Int?
  uploadedAt  DateTime @default(now())

  @@index([messageId])
  @@index([kind])
}

enum MessageAttachmentKind {
  FILE
  VIDEO_NOTE
  AUDIO_NOTE
  IMAGE
}

enum MessageSource {
  WEB
  MOBILE
  API
  SYSTEM       // service messages: "X joined", "channel renamed", etc.
}

enum MessageEventKind {
  /// "<name> started a call" card with a Join button. Payload:
  /// { meetingId: string }.
  CALL_STARTED
  /// "Call ended" card with optional duration + transcript link.
  /// Payload: { meetingId, durationSec?, hasTranscript? }.
  CALL_ENDED
  /// Member added/removed; payload: { userId, action: 'added' | 'removed' }.
  MEMBER_CHANGED
  /// Channel renamed; payload: { from, to }.
  CHANNEL_RENAMED
}

model MessageReaction {
  messageId String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation("MessageReactor", fields: [userId], references: [id], onDelete: Cascade)
  // Unicode emoji (single code point or ZWJ sequence). One reaction per
  // emoji per user per message.
  emoji     String
  createdAt DateTime @default(now())

  @@id([messageId, userId, emoji])
  @@index([messageId, emoji])
}

model MessageMention {
  messageId String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation("MessageMentioned", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([messageId, userId])
  @@index([userId, createdAt])
}

// ============================================================================
// CALENDAR EVENTS
// Lightweight personal/team calendar entries that aren't tasks and aren't
// active meetings — planning items, deadlines, time-off, all-hands etc.
// Visibility = creator + attendees (a-la Google Calendar). Tasks and Meetings
// remain separate first-class entities; the calendar grid renders all three.
// ============================================================================

model CalendarEvent {
  id          String       @id @default(cuid())
  title       String
  description String?      @db.Text
  /// Optional project scoping — appears in that project's calendar feed.
  projectId   String?
  project     Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  /// Start instant (UTC). For all-day events, midnight in the user's tz.
  startAt     DateTime
  /// End instant. For all-day events, the next midnight (exclusive).
  endAt       DateTime
  /// True = render as a date-only chip, ignore time. False = time-bound.
  isAllDay    Boolean      @default(false)
  /// Where the event happens (room, address, video link). Free-form.
  location    String?

  createdById String
  createdBy   User         @relation("CalendarEventCreator", fields: [createdById], references: [id])

  attendees   CalendarEventAttendee[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([startAt, endAt])
  @@index([projectId, startAt])
  @@index([createdById, startAt])
}

model CalendarEventAttendee {
  eventId   String
  event     CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation("CalendarEventAttendee", fields: [userId], references: [id], onDelete: Cascade)
  /// Optional response — null = no decision yet.
  response  EventResponse?
  createdAt DateTime      @default(now())

  @@id([eventId, userId])
  @@index([userId, createdAt])
}

enum EventResponse {
  ACCEPTED
  DECLINED
  TENTATIVE
}

/// Custom fields (Phase 3): per-project field definitions and
/// per-task values. Additive — no existing data to backfill.
enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  CHECKBOX
  SELECT
  MULTI_SELECT
  URL
}

model CustomFieldDefinition {
  id        String          @id @default(cuid())
  projectId String
  project   Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  type      CustomFieldType
  /// SELECT / MULTI_SELECT options (JSON array of strings); null for others.
  options   Json?
  /// Display order within the project.
  order     Int
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  values    CustomFieldValue[]

  @@index([projectId, order])
}

model CustomFieldValue {
  id      String                @id @default(cuid())
  fieldId String
  field   CustomFieldDefinition @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  taskId  String
  task    Task                  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  /// Stringified value: raw text/number/ISO-date/url, "true"/"false" for
  /// CHECKBOX, or a JSON string array for MULTI_SELECT.
  value   String

  @@unique([fieldId, taskId])
  @@index([taskId])
}

/// Automations (Phase 4): per-project rules that run an action
/// when a trigger fires on a task. Additive — best-effort execution never
/// blocks the underlying task change.
enum AutomationTrigger {
  /// Fires when a task's internal status changes to the configured column.
  CARD_ENTERS_COLUMN
  /// Fires when a task is created in the project.
  TASK_CREATED
}

enum AutomationActionType {
  SET_ASSIGNEE
  SET_PRIORITY
  ADD_COMMENT
  SET_SWIMLANE
}

model AutomationRule {
  id            String               @id @default(cuid())
  projectId     String
  project       Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name          String
  enabled       Boolean              @default(true)
  trigger       AutomationTrigger
  /// Trigger params, e.g. { "status": "DONE" } — which column entry fires it.
  triggerConfig Json
  actionType    AutomationActionType
  /// Action params, e.g. { "userId": "..." } / { "priority": "HIGH" } /
  /// { "body": "..." } / { "swimlaneId": "..." }.
  actionConfig  Json
  order         Int                  @default(0)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([projectId, enabled])
}

/// Document (wiki page) in a project. Nestable into a tree via
/// parentId; Markdown content.
model Document {
  id          String     @id @default(cuid())
  projectId   String
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  content     String     @default("")
  /// Parent document for nesting; null = top level.
  parentId    String?
  parent      Document?  @relation("DocTree", fields: [parentId], references: [id], onDelete: Cascade)
  children    Document[] @relation("DocTree")
  order       Int        @default(0)
  /// User id of the creator (no FK — soft reference).
  createdById String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([projectId, parentId, order])
}

/// Org-wide Knowledge Base space (TEAMLY-style «Пространство»). Top-level
/// container for a tree of articles. Distinct from `Space` (which groups
/// projects).
/// Draft articles are hidden from search and shown muted in the tree to the
/// people who can edit; published ones are the normal readable state.
enum KnowledgeArticleStatus {
  DRAFT
  PUBLISHED
}

/// Space visibility. PUBLIC: any authenticated user can read (default —
/// preserves the org-wide model). PRIVATE: only members + global ADMIN/PM.
enum KnowledgeSpaceVisibility {
  PUBLIC
  PRIVATE
}

/// Per-space role. EDITOR: read + write content. MANAGER: + manage settings,
/// members and visibility. Global ADMIN/PM act as MANAGER on every space.
enum KnowledgeSpaceRole {
  EDITOR
  MANAGER
}

model KnowledgeSpace {
  id          String                   @id @default(cuid())
  name        String
  description String?
  /// Emoji or short icon for the space.
  icon        String?
  color       String?
  visibility  KnowledgeSpaceVisibility @default(PUBLIC)
  order       Int                      @default(0)
  archivedAt  DateTime?
  createdById String?
  /// Mirror provenance for imported spaces (e.g. "teamly") + the external id;
  /// drives idempotent re-sync. NULL for spaces created locally.
  externalSource String?
  externalId     String?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  articles    KnowledgeArticle[]
  favorites   KnowledgeFavorite[]
  templates   KnowledgeTemplate[]
  tables      KnowledgeTable[]
  members     KnowledgeSpaceMember[]

  @@unique([externalSource, externalId])
  @@index([archivedAt, order])
}

/// Membership of a (typically PRIVATE) space. `userId` is a soft ref (no FK).
model KnowledgeSpaceMember {
  id        String             @id @default(cuid())
  spaceId   String
  space     KnowledgeSpace     @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  userId    String
  role      KnowledgeSpaceRole @default(EDITOR)
  createdAt DateTime           @default(now())

  @@unique([spaceId, userId])
  @@index([userId])
}

/// Article templates (TEAMLY «Шаблоны статей»). ACCOUNT templates apply in any
/// space; SPACE templates belong to one space. Managed by ADMIN/PM.
enum KnowledgeTemplateScope {
  ACCOUNT
  SPACE
}

model KnowledgeTemplate {
  id          String                 @id @default(cuid())
  name        String
  description String?
  icon        String?
  scope       KnowledgeTemplateScope @default(ACCOUNT)
  spaceId     String?
  space       KnowledgeSpace?        @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  /// Markdown body copied into new articles created from this template.
  content     String                 @default("")
  order       Int                    @default(0)
  createdById String?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@index([scope, spaceId, order])
}

/// Smart-table column types (TEAMLY «свойства»). v1 subset: the property kinds
/// that don't need relations/rollup/formula.
enum KnowledgeColumnType {
  TEXT
  NUMBER
  DATE
  CHECKBOX
  SELECT
  URL
  RELATION
  FORMULA
}

/// A smart table (TEAMLY «Умная таблица») — a lightweight database living in a
/// space: typed columns + rows. Cell values are stored as a JSON map on the row
/// (columnId → string), updated atomically per-cell via jsonb_set.
model KnowledgeTable {
  id          String                 @id @default(cuid())
  spaceId     String
  space       KnowledgeSpace         @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  name        String                 @default("Новая таблица")
  icon        String?
  order       Int                    @default(0)
  createdById String?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  columns     KnowledgeTableColumn[]
  rows        KnowledgeTableRow[]

  @@index([spaceId, order])
}

model KnowledgeTableColumn {
  id        String             @id @default(cuid())
  tableId   String
  table     KnowledgeTable     @relation(fields: [tableId], references: [id], onDelete: Cascade)
  name      String             @default("Столбец")
  type      KnowledgeColumnType @default(TEXT)
  /// For SELECT: JSON array of option strings. Null otherwise.
  options   Json?
  order     Int                @default(0)
  createdAt DateTime           @default(now())

  @@index([tableId, order])
}

model KnowledgeTableRow {
  id        String         @id @default(cuid())
  tableId   String
  table     KnowledgeTable @relation(fields: [tableId], references: [id], onDelete: Cascade)
  /// columnId → cell value (always stored as string; typed on render).
  values    Json           @default("{}")
  order     Int            @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([tableId, order])
}

/// A Knowledge Base article (TEAMLY «Статья»). Markdown content, nested in a
/// tree within a space (parent/children), ordered among siblings.
model KnowledgeArticle {
  id          String             @id @default(cuid())
  spaceId     String
  space       KnowledgeSpace     @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  title       String             @default("Без названия")
  /// Markdown body, rendered via renderRichText.
  content     String             @default("")
  icon        String?
  status      KnowledgeArticleStatus @default(PUBLISHED)
  parentId    String?
  parent      KnowledgeArticle?  @relation("KbTree", fields: [parentId], references: [id], onDelete: Cascade)
  children    KnowledgeArticle[] @relation("KbTree")
  order       Int                @default(0)
  /// Soft refs (no FK) to the User who created / last edited.
  createdById String?
  updatedById String?
  /// Mirror provenance for imported articles (e.g. "teamly") + external id +
  /// the source's last-modified timestamp; drives idempotent re-sync and lets
  /// the importer skip unchanged articles. NULL for locally-created articles.
  externalSource    String?
  externalId        String?
  externalUpdatedAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  favorites   KnowledgeFavorite[]
  versions    KnowledgeArticleVersion[]
  comments    KnowledgeComment[]
  reactions   KnowledgeReaction[]
  views       KnowledgeArticleView[]
  reviews     KnowledgeArticleReview[]
  attachments KnowledgeAttachment[]

  @@unique([externalSource, externalId])
  @@index([spaceId, parentId, order])
  @@index([status])
}

/// A file attached to a KB article (TEAMLY «вложения»). Bytes live in S3
/// (storageKey); access follows the article's space. uploadedById is a soft ref.
model KnowledgeAttachment {
  id           String           @id @default(cuid())
  articleId    String
  article      KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  filename     String
  mimeType     String
  sizeBytes    Int
  storageKey   String
  uploadedById String?
  uploadedAt   DateTime         @default(now())

  @@index([articleId])
}

enum KnowledgeReviewState {
  PENDING
  APPROVED
  REJECTED
}

/// An approval request on an article (TEAMLY «Согласование»). One PENDING review
/// at a time gates publishing; APPROVED publishes the article. User refs are soft.
model KnowledgeArticleReview {
  id            String               @id @default(cuid())
  articleId     String
  article       KnowledgeArticle     @relation(fields: [articleId], references: [id], onDelete: Cascade)
  requestedById String
  reviewerId    String
  state         KnowledgeReviewState @default(PENDING)
  comment       String?
  createdAt     DateTime             @default(now())
  resolvedAt    DateTime?

  @@index([articleId, createdAt])
  @@index([reviewerId, state])
  // NOTE: a partial unique index enforces "at most one PENDING review per
  // article" — `CREATE UNIQUE INDEX ... ON (articleId) WHERE state='PENDING'`.
  // Prisma can't express partial unique indexes, so it lives in the migration
  // (20260623090000_knowledge_review). requestReviewAction catches its P2002.
}

/// One row per (article, user, day) — dedups views so the count is "unique
/// readers per day", not refresh spam. `userId` is a soft ref (no FK).
model KnowledgeArticleView {
  id        String           @id @default(cuid())
  articleId String
  article   KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  userId    String
  /// 'YYYY-MM-DD' bucket for daily dedup + time-series.
  day       String
  createdAt DateTime         @default(now())

  @@unique([articleId, userId, day])
  @@index([articleId])
  @@index([day])
}

/// A comment on an article (TEAMLY обсуждение). One-level replies via parentId.
/// `authorId` is a soft ref (no FK), consistent with the rest of the KB.
model KnowledgeComment {
  id        String              @id @default(cuid())
  articleId String
  article   KnowledgeArticle    @relation(fields: [articleId], references: [id], onDelete: Cascade)
  authorId  String
  body      String
  parentId  String?
  parent    KnowledgeComment?   @relation("KbCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   KnowledgeComment[]  @relation("KbCommentReplies")
  reactions KnowledgeReaction[]
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([articleId, createdAt])
}

/// An emoji reaction on an article OR a comment (exactly one target set).
model KnowledgeReaction {
  id        String            @id @default(cuid())
  userId    String
  emoji     String
  articleId String?
  article   KnowledgeArticle? @relation(fields: [articleId], references: [id], onDelete: Cascade)
  commentId String?
  comment   KnowledgeComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt DateTime          @default(now())

  @@unique([userId, articleId, emoji])
  @@unique([userId, commentId, emoji])
  @@index([articleId])
  @@index([commentId])
}

/// A point-in-time snapshot of an article's title/content (TEAMLY «Предыдущие
/// версии»). Captured on each meaningful edit so changes can be reviewed and
/// restored.
model KnowledgeArticleVersion {
  id         String           @id @default(cuid())
  articleId  String
  article    KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  title      String
  content    String
  icon       String?
  editedById String?
  createdAt  DateTime         @default(now())

  @@index([articleId, createdAt])
}

/// A user's starred space or article (exactly one of spaceId/articleId set).
/// `userId` is a soft ref (no FK) to keep the User model untouched.
model KnowledgeFavorite {
  id         String            @id @default(cuid())
  userId     String
  spaceId    String?
  space      KnowledgeSpace?   @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  articleId  String?
  article    KnowledgeArticle? @relation(fields: [articleId], references: [id], onDelete: Cascade)
  createdAt  DateTime          @default(now())

  @@unique([userId, spaceId])
  @@unique([userId, articleId])
  @@index([userId])
}
